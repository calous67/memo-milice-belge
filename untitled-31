        function loadMilitaryData() {
            try {
                const saved = localStorage.getItem(MILITARY_STORAGE_KEY);
                if (saved) {
                    const parsed = JSON.parse(saved);
                    if (parsed.entries) return parsed;
                }
            } catch (e) {}
            localStorage.setItem(MILITARY_STORAGE_KEY, JSON.stringify(defaultMilitaryData));
            return JSON.parse(JSON.stringify(defaultMilitaryData));
        }

        function saveMilitaryData() {
            try {
                const dataToSave = {
                    entries: entriesData,
                    veterans: veteransData,
                    insignes: insignesData,
                    nextEntryId: nextEntryId,
                    nextVeteranId: nextVeteranId,
                    nextInsigneId: nextInsigneId
                };
                localStorage.setItem(MILITARY_STORAGE_KEY, JSON.stringify(dataToSave));
            } catch (e) {}
        }

        function saveAllData() {
            saveMilitaryData();
            saveTextsData();
            saveLogos();
        }

        function loadTexts() {
            try {
                const saved = localStorage.getItem(TEXTS_KEY);
                if (saved) {
                    const parsed = JSON.parse(saved);
                    if (parsed.forceTerre) return parsed;
                }
            } catch (e) {}
            localStorage.setItem(TEXTS_KEY, JSON.stringify(defaultTexts));
            return JSON.parse(JSON.stringify(defaultTexts));
        }

