                    'forcesTitle', 'forcesBadge', 'insignesTitle', 'veteransTitle',
                    'adminTitle', 'addEntry', 'addInsigne', 'entriesList', 'addVeteran', 'stats',
                    'totalEntries', 'totalVeterans', 'totalInsignes',
                    'btnDetail', 'btnAdd', 'btnEdit', 'btnDelete', 'photos', 'addedOn', 'copyright', 'footerName'
                ];
                fields.forEach(f => {
                    const el = document.getElementById('text' + f.charAt(0).toUpperCase() + f.slice(1));
                    if (el) dataToSave[f] = el.value;
                });
