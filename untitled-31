        function changePassword(currentPassword, newPassword) {
            if (btoa(currentPassword) !== PASSWORD_HASH) {
                showNotification('❌ Mot de passe actuel incorrect.', 'error');
                return false;
            }
            if (newPassword.length < 6) {
                showNotification('❌ Le nouveau mot de passe doit faire au moins 6 caractères.', 'error');
                return false;
            }
            ADMIN_PASSWORD = newPassword;
            PASSWORD_HASH = btoa(newPassword);
            sessionStorage.setItem('admin_hash', PASSWORD_HASH);
            document.getElementById('defaultPasswordDisplay').textContent = newPassword;
            showNotification('✅ Mot de passe changé avec succès !', 'success');
            return true;
        }

        document.getElementById('changePasswordForm').addEventListener('submit', function(e) {
            e.preventDefault();
            const current = document.getElementById('currentPassword').value;
            const newPass = document.getElementById('newPassword').value;
            const confirm = document.getElementById('confirmPassword').value;

            if (newPass !== confirm) {
                showNotification('❌ Les mots de passe ne correspondent pas.', 'error');
                return;
            }

            if (changePassword(current, newPass)) {
                document.getElementById('changePasswordForm').reset();
                showPage('accueil');
            }
        });

