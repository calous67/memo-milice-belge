        // ============================================================
        document.getElementById('addEntryForm').addEventListener('submit', function(e) {
            e.preventDefault();
            const title = document.getElementById('entryTitle').value.trim();
            const period = document.getElementById('entryPeriod').value;
            const force = document.getElementById('entryForce').value;
            const location = document.getElementById('entryLocation').value.trim();
            const description = document.getElementById('entryDesc').value.trim();
            const tagsStr = document.getElementById('entryTags').value.trim();
            const tags = tagsStr ? tagsStr.split(',').map(t => t.trim()).filter(t => t) : ['Mémoire'];
            const photosInput = document.getElementById('entryPhotos');
            if (!title || !period || !force || !description) {
                showNotification('❌ Veuillez remplir tous les champs obligatoires.', 'error');
                return;
            }
            let photoUrls = [];
            if (photosInput.files.length > 0) {
                for (let i = 0; i < photosInput.files.length; i++) {
                    photoUrls.push(URL.createObjectURL(photosInput.files[i]));
                }
            } else {
                photoUrls.push('https://via.placeholder.com/400x200/1a1510/8b7a5a?text=' + encodeURIComponent(title));
                // Ajouter des photos supplémentaires
                const extraPhotos = [
                    'https://images.unsplash.com/photo-1504384308090-c894fdcc538d?w=400',
                    'https://images.unsplash.com/photo-1519681393784-d120267933ba?w=400'
                ];
                photoUrls.push(extraPhotos[0]);
                photoUrls.push(extraPhotos[1]);
            }
            const newEntry = {
                id: nextEntryId++,
                title,
                period,
                force,
                location: location || 'Lieu inconnu',
                description,
                tags,
                photos: photoUrls,
                createdAt: new Date().toISOString()
            };
            entriesData.push(newEntry);
            saveMilitaryData();
            document.getElementById('addEntryForm').reset();
            document.getElementById('entryPhotos').value = '';
            renderAll();
            showNotification(`✅ "${title}" ajouté !`, 'success');
        });

