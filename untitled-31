        function loadLogos() {
            try {
                const saved = localStorage.getItem(LOGOS_KEY);
                if (saved) {
                    const parsed = JSON.parse(saved);
                    if (parsed.terre !== undefined) return parsed;
                }
            } catch (e) {}
            const def = {
                terre: '',
                air: '',
                mer: '',
                medical: '',
                logistique: '',
                cadets: '',
                aeroportee: '',
                sp: '',
                police: '',
                fba: '',
                otan: ''
            };
            localStorage.setItem(LOGOS_KEY, JSON.stringify(def));
            return JSON.parse(JSON.stringify(def));
        }

        function saveLogos() {
            try {
                localStorage.setItem(LOGOS_KEY, JSON.stringify(logos));
            } catch (e) {}
        }

        function getLogoUrl(forceKey) {
            const map = {
                'Terre': 'terre',
                'Air': 'air',
                'Mer': 'mer',
                'Médical': 'medical',
                'Logistique': 'logistique',
                'Cadets': 'cadets',
                'Aéroportée': 'aeroportee',
                'SP': 'sp',
                'Police Militaire': 'police',
                'FBA': 'fba',
                'OTAN': 'otan'
            };
            const key = map[forceKey] || forceKey.toLowerCase();
            return logos[key] || '';
        }

        function getLogoHtml(forceKey) {
            const url = getLogoUrl(forceKey);
            if (url) {
                return `<img src="${url}" alt="${forceKey}" style="width:28px;height:28px;object-fit:contain;border-radius:4px;">`;
            }
            const emojiMap = {
                'Terre': '🪖',
                'Air': '✈️',
                'Mer': '⚓',
                'Médical': '🏥',
                'Logistique': '📦',
                'Cadets': '🎓',
                'Aéroportée': '🪂',
                'SP': '⭐',
                'Police Militaire': '👮',
                'FBA': '🇩🇪',
                'OTAN': '🌍'
            };
            return emojiMap[forceKey] || '🎖️';
        }

        function renderLogosAdmin() {
            const container = document.getElementById('logosContainer');
            if (!container) return;

            const forces = [
                { key: 'terre', label: 'Terre', emoji: '🪖' },
                { key: 'air', label: 'Air', emoji: '✈️' },
                { key: 'mer', label: 'Mer', emoji: '⚓' },
                { key: 'medical', label: 'Médical', emoji: '🏥' },
                { key: 'logistique', label: 'Logistique', emoji: '📦' },
                { key: 'cadets', label: 'Cadets', emoji: '🎓' },
                { key: 'aeroportee', label: 'Aéroportée', emoji: '🪂' },
                { key: 'sp', label: 'SP - Spéciales', emoji: '⭐' },
                { key: 'police', label: 'Police Militaire', emoji: '👮' },
                { key: 'fba', label: 'FBA - Allemagne', emoji: '🇩🇪' },
                { key: 'otan', label: 'OTAN', emoji: '🌍' }
            ];

            container.innerHTML = forces.map(f => {
                const currentLogo = logos[f.key] || '';
                const previewHtml = currentLogo ?
                    `<img src="${currentLogo}" alt="${f.label}">` :
                    `<span style="font-size:24px;">${f.emoji}</span>`;

                return `
                    <div class="logo-item">
                        <div class="preview">${previewHtml}</div>
                        <span class="name">${f.label}</span>
                        <span class="status">${currentLogo ? '✅ Logo personnalisé' : '🔲 Logo par défaut'}</span>
                        <div class="actions">
                            <label class="file-label" onclick="document.getElementById('logoInput_${f.key}').click()">📤 Changer</label>
                            <input type="file" id="logoInput_${f.key}" accept="image/*" onchange="uploadLogo('${f.key}')">
                            ${currentLogo ? `<button class="btn-reset" onclick="resetLogo('${f.key}')">🔄 Réinitialiser</button>` : ''}
                        </div>
                    </div>
                `;
            }).join('');
        }

        function uploadLogo(key) {
            const input = document.getElementById('logoInput_' + key);
            if (!input || !input.files || !input.files[0]) return;
            const file = input.files[0];
            const reader = new FileReader();
            reader.onload = function(e) {
                logos[key] = e.target.result;
                saveLogos();
                renderLogosAdmin();
                renderForcesNav();
                showNotification('✅ Logo mis à jour !', 'success');
            };
            reader.readAsDataURL(file);
        }

        function resetLogo(key) {
            if (confirm('Réinitialiser le logo par défaut ?')) {
                logos[key] = '';
                saveLogos();
                renderLogosAdmin();
                renderForcesNav();
                showNotification('🔄 Logo réinitialisé !', 'success');
            }
        }

        function resetAllLogos() {
            if (confirm('⚠️ Réinitialiser tous les logos ?')) {
                const keys = ['terre', 'air', 'mer', 'medical', 'logistique', 'cadets', 'aeroportee', 'sp', 'police', 'fba',
                    'otan'
                ];
                keys.forEach(k => logos[k] = '');
                saveLogos();
                renderLogosAdmin();
                renderForcesNav();
                showNotification('🔄 Tous les logos réinitialisés !', 'success');
            }
        }

