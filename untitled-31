        // ============================================================
        // FONCTIONS UTILES
        // ============================================================
        function showNotification(message, type = 'success') {
            const existing = document.querySelector('.notification');
            if (existing) existing.remove();

            const notif = document.createElement('div');
            notif.className = `notification ${type}`;
            notif.textContent = message;
            document.body.appendChild(notif);

            setTimeout(() => {
                notif.style.opacity = '0';
                notif.style.transition = 'opacity 0.5s';
                setTimeout(() => notif.remove(), 500);
            }, 4000);
        }

        function formatDate(dateString) {
            const d = new Date(dateString);
            return d.toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit', year: 'numeric' });
        }

        function getImageUrl(entry) {
            if (entry.photos && entry.photos.length > 0) return entry.photos[0];
            return 'https://via.placeholder.com/400x200/1a1510/8b7a5a?text=' + encodeURIComponent(entry.title);
        }

        function getPeriodEmoji(period) {
            const map = { 'Avant 1900': '⚜️', '14-18': '📜', '40-45': '⚔️', 'Après-Guerre': '🕊️' };
            return map[period] || '🎖️';
        }

        function getForceDisplay(force) {
            const map = {
                'Terre': texts.forceTerre || 'Terre',
                'Air': texts.forceAir || 'Air',
                'Mer': texts.forceMer || 'Mer',
                'Médical': texts.forceMedical || 'Médical',
                'Logistique': texts.forceLogistique || 'Logistique',
                'Cadets': texts.forceCadets || 'Cadets',
                'Aéroportée': texts.forceAeroportee || 'Aéroportée',
                'SP': texts.forceSP || 'SP',
                'Police Militaire': texts.forcePolice || 'Police Militaire',
                'FBA': texts.forceFBA || 'FBA',
                'OTAN': texts.forceOTAN || 'OTAN'
            };
            return map[force] || force;
        }

        function updateStats() {
            const periods = [...new Set(entriesData.map(e => e.period))];
            const forces = [...new Set(entriesData.map(e => e.force))];
            document.getElementById('statPeriods').textContent = periods.length;
            document.getElementById('statForces').textContent = forces.length;
            document.getElementById('statVeterans').textContent = veteransData.length;
            document.getElementById('veteranCount').textContent = veteransData.length;
            document.getElementById('insigneCount').textContent = insignesData.length;
        }

        // ============================================================
        // NAVIGATION
        // ============================================================
        function showPage(page) {
            ['page-accueil', 'page-admin', 'page-logos', 'page-texts', 'page-force', 'page-insigne', 'page-categorie',
                'page-contact', 'page-documentation', 'page-change-password'
            ].forEach(id => {
                document.getElementById(id).style.display = 'none';
            });
            if (page === 'accueil') {
                document.getElementById('page-accueil').style.display = 'block';
            } else if (page === 'admin') {
                document.getElementById('page-admin').style.display = 'block';
                renderAdminList();
                renderVeteransAdminList();
                renderInsignesAdminList();
            } else if (page === 'logos') {
                document.getElementById('page-logos').style.display = 'block';
                renderLogosAdmin();
            } else if (page === 'texts') {
                document.getElementById('page-texts').style.display = 'block';
                loadTextsForm();
            } else if (page === 'force') {
                document.getElementById('page-force').style.display = 'block';
            } else if (page === 'insigne') {
                document.getElementById('page-insigne').style.display = 'block';
            } else if (page === 'categorie') {
                document.getElementById('page-categorie').style.display = 'block';
            } else if (page === 'contact') {
                document.getElementById('page-contact').style.display = 'block';
            } else if (page === 'documentation') {
                document.getElementById('page-documentation').style.display = 'block';
            } else if (page === 'change-password') {
                document.getElementById('page-change-password').style.display = 'block';
