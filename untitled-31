        function openVeteranModal(veteranId) {
            const veteran = veteransData.find(v => v.id === veteranId);
            if (!veteran) return;
            const modal = document.getElementById('detailModal');
            const body = document.getElementById('modalBody');
            body.innerHTML = `
                <button class="modal-close" onclick="closeModal()">✕</button>
                <div class="modal-title">🕊️ ${veteran.name}</div>
                <div class="modal-sub">📅 ${veteran.period}</div>
                <div class="modal-desc"><strong>${veteran.info || 'Héros'}</strong></div>
