        }

        // ============================================================
        // MODAL
        // ============================================================
        function openModal(entryId) {
            const entry = entriesData.find(e => e.id === entryId);
            if (!entry) return;
            const modal = document.getElementById('detailModal');
            const body = document.getElementById('modalBody');
            body.innerHTML = `
                <button class="modal-close" onclick="closeModal()">✕</button>
                <div class="modal-title">${getPeriodEmoji(entry.period)} ${entry.title}</div>
                <div class="modal-sub">📅 ${entry.period} • ⚔️ ${getForceDisplay(entry.force)} • 📍 ${entry.location || 'Lieu inconnu'}</div>
                <div class="modal-desc">${entry.description}</div>
                <div style="display:flex;flex-wrap:wrap;gap:6px;margin:6px 0;">
                    ${entry.tags.map(t => `<span style="background:rgba(139,122,90,0.1);color:var(--text-muted);padding:2px 8px;border-radius:8px;font-size:9px;">#${t}</span>`).join('')}
                </div>
                <div class="modal-gallery">
                    ${entry.photos.map(p => `<img src="${p}" alt="${entry.title}" onerror="this.src='https://via.placeholder.com/90/1a1510/8b7a5a?text=Photo'">`).join('')}
