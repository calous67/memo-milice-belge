            border-radius: 6px;
            margin-bottom: 4px;
            border-left: 2px solid var(--primary);
            flex-wrap: wrap;
            gap: 4px;
        }

        .veteran-admin-item .v-info .v-name {
            font-size: 11px;
            font-weight: 500;
            color: var(--text);
        }

        .veteran-admin-item .v-info .v-period {
            font-size: 8px;
            color: var(--text-muted);
            margin-left: 6px;
        }

        .veteran-admin-item .v-actions {
            display: flex;
            gap: 4px;
        }

        /* ============================================================
           BOUTON PDF
           ============================================================ */
        .btn-pdf {
            background: #8a2a2a;
            color: white;
            padding: 8px 20px;
            border: none;
            border-radius: 6px;
            font-weight: 600;
            font-size: 11px;
            cursor: pointer;
            transition: var(--transition);
            width: auto;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .btn-pdf:hover {
            background: #aa3a3a;
            transform: translateY(-2px);
        }

        /* ============================================================
           SÉLECTEUR DE LANGUE
           ============================================================ */
        .lang-selector {
            display: flex;
            gap: 4px;
            align-items: center;
        }

        .lang-selector .lang-btn {
            background: transparent;
            border: 1px solid var(--border);
            color: var(--text-muted);
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 9px;
            cursor: pointer;
            transition: var(--transition);
            font-weight: 600;
        }

        .lang-selector .lang-btn:hover {
            border-color: var(--primary);
            color: var(--text);
        }

        .lang-selector .lang-btn.active {
            background: var(--primary);
            color: #0d0a08;
            border-color: var(--primary);
        }

        /* ============================================================
           FOOTER
           ============================================================ */
        .footer {
            background: var(--bg-card);
            border-top: 1px solid var(--border);
            padding: 16px 16px;
            text-align: center;
            margin-top: 20px;
        }

        .footer-content {
            max-width: 1200px;
            margin: 0 auto;
        }

        .footer .logo {
            font-size: 13px;
            margin-bottom: 4px;
        }

        .footer .copy {
            font-size: 9px;
            color: var(--text-muted);
        }

        .footer .links {
            display: flex;
            justify-content: center;
            gap: 12px;
            flex-wrap: wrap;
            margin-top: 6px;
        }

        .footer .links a {
            color: var(--text-muted);
            text-decoration: none;
            font-size: 9px;
            transition: var(--transition);
        }

        .footer .links a:hover {
            color: var(--text);
        }

        /* ============================================================
           RESPONSIVE
           ============================================================ */
        @media (max-width: 768px) {
            .hero { min-height: 35vh; padding: 20px 16px; }
            .hero h1 { font-size: 26px; letter-spacing: 1px; }
            .hero-sub { font-size: 10px; letter-spacing: 3px; }
            .hero-stats { gap: 14px; }
            .hero-stat .number { font-size: 16px; }
            .cards-grid { grid-template-columns: 1fr; }
            .forces-nav-grid { grid-template-columns: repeat(3, 1fr); }
            .insignes-nav-grid { grid-template-columns: repeat(2, 1fr); }
            .force-entries { grid-template-columns: 1fr; }
            .categorie-entries { grid-template-columns: 1fr; }
            .header-inner { flex-direction: column; align-items: stretch; }
            .nav { justify-content: center; }
            .veteran-item { flex-direction: column; align-items: flex-start; }
            .logos-grid { grid-template-columns: repeat(2, 1fr); }
            .logo-belge-container { flex-direction: column; align-items: center; }
            .logo-text-container { border-left: none; padding-left: 0; align-items: center; }
            .flag-belgium { margin-top: 4px; }
            .breadcrumb { font-size: 9px; padding: 4px 8px; }
            .login-box { padding: 25px 20px; margin: 10px; }
            .admin-grid { grid-template-columns: 1fr; }
            .contact-grid { grid-template-columns: 1fr; }
            .doc-grid { grid-template-columns: 1fr; }
        }

        @media (max-width: 480px) {
            .hero h1 { font-size: 20px; }
            .forces-nav-grid { grid-template-columns: repeat(2, 1fr); }
            .insignes-nav-grid { grid-template-columns: 1fr 1fr; }
            .logos-grid { grid-template-columns: 1fr; }
            .hero-btn { padding: 8px 20px; font-size: 9px; }
            .logo-header .logo-text { font-size: 11px; }
        }

        /* ============================================================
           SCROLLBAR
           ============================================================ */
        ::-webkit-scrollbar { width: 4px; }
        ::-webkit-scrollbar-track { background: var(--bg); }
        ::-webkit-scrollbar-thumb { background: var(--primary); border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--primary-light); }

        /* ============================================================
           PHOTOS ADDITIONNELLES - STYLE
           ============================================================ */
        .photo-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
            gap: 8px;
            margin: 10px 0;
        }

        .photo-grid .photo-item {
            border-radius: 8px;
            overflow: hidden;
            border: 1px solid var(--border);
            transition: var(--transition);
            cursor: pointer;
            aspect-ratio: 1/1;
        }

        .photo-grid .photo-item:hover {
            transform: scale(1.05);
            border-color: var(--primary);
        }

        .photo-grid .photo-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
    </style>
</head>
