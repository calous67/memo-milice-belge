            if (confirm(`Supprimer "${entry.title}" ?`)) {
                entriesData = entriesData.filter(e => e.id !== id);
                saveMilitaryData();
                renderAll();
                showNotification(`🗑️ "${entry.title}" supprimé.`, 'success');
