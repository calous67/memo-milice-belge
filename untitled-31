<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Histoire Militaire Belge - Patrimoine & Forces Armées</title>
    <!-- ============================================================
    BIBLIOTHÈQUES POUR PDF ET MULTILINGUE
    ============================================================ -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js" integrity="sha512-GsLlZN/3F2ErC5ifS5QtgpiJtWd43JWSuIgh7mbzZ8zBps+dvLusV+eNQATqgA/HdeKFVgA5v3S/cIrLF7QnIg==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <style>
        /* ============================================================
           STYLES COMPLETS - DESIGN PROFESSIONNEL
           ============================================================ */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #0d0a08;
            color: #d4ccc4;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* ============================================================
           VARIABLES
           ============================================================ */
        :root {
            --primary: #8b7a5a;
            --primary-light: #b0a898;
            --primary-dark: #5a4a3a;
            --bg: #0d0a08;
            --bg-card: #16120e;
            --bg-card-hover: #1f1a14;
            --text: #d4ccc4;
            --text-muted: #8a7a6a;
            --border: rgba(139, 122, 90, 0.15);
            --radius: 14px;
            --shadow: 0 8px 40px rgba(0, 0, 0, 0.6);
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* ============================================================
           BANNIÈRE HERO
           ============================================================ */
        .hero {
            position: relative;
            min-height: 45vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(160deg, #080604 0%, #16120e 50%, #0d0a08 100%);
            border-bottom: 1px solid var(--border);
            padding: 40px 20px 30px;
            overflow: hidden;
        }

        .hero::after {
            content: '';
            position: absolute;
            inset: 0;
            background: 
                radial-gradient(ellipse at 20% 40%, rgba(139, 122, 90, 0.06) 0%, transparent 60%),
                radial-gradient(ellipse at 80% 60%, rgba(139, 122, 90, 0.04) 0%, transparent 60%);
            pointer-events: none;
        }

        .hero-particles {
            position: absolute;
            inset: 0;
            overflow: hidden;
            pointer-events: none;
        }

        .hero-particles span {
            position: absolute;
            width: 3px;
            height: 3px;
            background: rgba(139, 122, 90, 0.08);
            border-radius: 50%;
            animation: floatParticle 25s linear infinite;
        }

        .hero-particles span:nth-child(1) { left: 5%; animation-duration: 22s; }
        .hero-particles span:nth-child(2) { left: 15%; animation-duration: 18s; animation-delay: 2s; }
        .hero-particles span:nth-child(3) { left: 25%; animation-duration: 26s; animation-delay: 4s; }
        .hero-particles span:nth-child(4) { left: 35%; animation-duration: 20s; animation-delay: 1s; }
        .hero-particles span:nth-child(5) { left: 45%; animation-duration: 24s; animation-delay: 3s; }
        .hero-particles span:nth-child(6) { left: 55%; animation-duration: 16s; animation-delay: 5s; }
        .hero-particles span:nth-child(7) { left: 65%; animation-duration: 28s; animation-delay: 2s; }
        .hero-particles span:nth-child(8) { left: 75%; animation-duration: 19s; animation-delay: 4s; }
        .hero-particles span:nth-child(9) { left: 85%; animation-duration: 23s; animation-delay: 1s; }
        .hero-particles span:nth-child(10) { left: 95%; animation-duration: 21s; animation-delay: 3s; }

        @keyframes floatParticle {
            0% { transform: translateY(100vh) rotate(0deg); opacity: 0; }
            10% { opacity: 1; }
            90% { opacity: 1; }
            100% { transform: translateY(-10vh) rotate(720deg); opacity: 0; }
        }

        .hero-content {
            position: relative;
            z-index: 2;
            text-align: center;
            max-width: 820px;
        }

        .logo-belge-container {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            margin-bottom: 12px;
        }

        .logo-belge-svg {
            width: 50px;
            height: 50px;
            filter: drop-shadow(0 0 30px rgba(139, 122, 90, 0.15));
            animation: logoPulse 3s ease-in-out infinite;
        }

        @keyframes logoPulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.03); }
        }

        .logo-belge-svg svg {
            width: 100%;
            height: 100%;
        }

        .logo-text-container {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            border-left: 2px solid rgba(139, 122, 90, 0.2);
            padding-left: 14px;
        }

        .logo-text-container .title {
            font-size: 12px;
            font-weight: 700;
            color: var(--primary-light);
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        .logo-text-container .sub {
            font-size: 8px;
            color: var(--text-muted);
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .logo-text-container .sub span {
            color: var(--primary);
        }

        .flag-belgium {
            display: flex;
            height: 25px;
            width: 38px;
            border-radius: 4px;
            overflow: hidden;
            border: 1px solid rgba(139, 122, 90, 0.2);
            margin-left: 4px;
        }

        .flag-belgium .black { background: #1a1410; flex: 1; }
        .flag-belgium .yellow { background: #b8860b; flex: 1; }
        .flag-belgium .red { background: #8b0000; flex: 1; }

        .hero h1 {
            font-size: 36px;
            font-weight: 700;
            color: var(--text);
            letter-spacing: 3px;
            line-height: 1.1;
            margin-bottom: 4px;
        }

        .hero h1 .highlight {
            color: var(--primary);
        }

        .hero-sub {
            font-size: 12px;
            color: var(--text-muted);
            letter-spacing: 4px;
            text-transform: uppercase;
            font-weight: 300;
            margin-bottom: 10px;
        }

        .hero-slogan {
            font-size: 15px;
            color: #9a8a7a;
            font-style: italic;
            font-weight: 300;
            margin-bottom: 18px;
        }

        .hero-slogan span {
            color: var(--primary-light);
        }

        .hero-divider {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 14px;
            max-width: 200px;
            margin: 0 auto 18px;
        }

        .hero-divider .line {
            flex: 1;
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--primary), transparent);
        }

        .hero-divider .diamond {
            color: var(--primary);
            font-size: 10px;
        }

        .hero-btn {
            display: inline-block;
            padding: 10px 32px;
            background: var(--primary);
            color: #0d0a08;
            font-weight: 700;
            font-size: 11px;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            border: none;
            border-radius: 50px;
            cursor: pointer;
            transition: var(--transition);
            text-decoration: none;
            box-shadow: 0 4px 20px rgba(139, 122, 90, 0.15);
        }

        .hero-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 35px rgba(139, 122, 90, 0.3);
            background: var(--primary-light);
        }

        .hero-stats {
            display: flex;
            justify-content: center;
            gap: 25px;
            margin-top: 20px;
            flex-wrap: wrap;
        }

        .hero-stat {
            text-align: center;
            padding: 0 8px;
        }

        .hero-stat .number {
            font-size: 20px;
            font-weight: 700;
            color: var(--primary);
            display: block;
        }

        .hero-stat .label {
            font-size: 8px;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* ============================================================
           HEADER NAV
           ============================================================ */
        .header {
            background: rgba(13, 10, 8, 0.95);
            border-bottom: 1px solid var(--border);
            padding: 6px 0;
            position: sticky;
            top: 0;
            z-index: 100;
            backdrop-filter: blur(20px);
        }

        .header-inner {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 16px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 4px;
        }

        .logo-header {
            display: flex;
            align-items: center;
            gap: 6px;
            text-decoration: none;
            cursor: pointer;
        }

        .logo-header svg {
            width: 24px;
            height: 24px;
            filter: drop-shadow(0 0 10px rgba(139, 122, 90, 0.1));
        }

        .logo-header .logo-text {
            font-size: 13px;
            font-weight: 700;
            color: var(--text);
            letter-spacing: 0.5px;
        }

        .logo-header .logo-text span {
            color: var(--primary);
        }

        .logo-header .logo-sub {
            font-size: 7px;
            color: var(--text-muted);
            letter-spacing: 1px;
            text-transform: uppercase;
            display: block;
            margin-top: -2px;
        }

        .nav {
            display: flex;
            gap: 3px;
            flex-wrap: wrap;
            align-items: center;
        }

        .nav a {
            color: var(--text-muted);
            text-decoration: none;
            padding: 3px 8px;
            border-radius: 5px;
            font-size: 10px;
            transition: var(--transition);
            cursor: pointer;
            white-space: nowrap;
        }

        .nav a:hover {
            color: var(--text);
            background: rgba(139, 122, 90, 0.06);
        }

        .nav a.admin {
            color: var(--primary);
            border: 1px solid rgba(139, 122, 90, 0.15);
        }

        .nav a.admin:hover {
            background: var(--primary);
            color: #0d0a08;
        }

        .nav a.custom {
            color: #4a8a4a;
            border: 1px solid rgba(74, 138, 74, 0.2);
        }

        .nav a.custom:hover {
            background: #4a8a4a;
            color: #0d0a08;
        }

        .nav a.contact-link {
            color: #4a8aaa;
            border: 1px solid rgba(74, 138, 170, 0.2);
        }

        .nav a.contact-link:hover {
            background: #4a8aaa;
            color: #0d0a08;
        }

        .nav a.doc-link {
            color: #8a6a4a;
            border: 1px solid rgba(138, 106, 74, 0.2);
        }

        .nav a.doc-link:hover {
            background: #8a6a4a;
            color: #0d0a08;
        }

        .nav a.lang-link {
            color: #6a8a8a;
            border: 1px solid rgba(106, 138, 138, 0.2);
            font-weight: 600;
        }

        .nav a.lang-link:hover {
            background: #6a8a8a;
            color: #0d0a08;
        }

        /* ============================================================
           LOGIN MODAL
           ============================================================ */
        .login-modal {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.9);
            z-index: 999;
            justify-content: center;
            align-items: center;
            backdrop-filter: blur(10px);
        }

        .login-modal.active {
            display: flex;
        }

        .login-box {
            background: var(--bg-card);
            border: 2px solid var(--border);
            border-radius: var(--radius);
            padding: 35px 30px;
            max-width: 400px;
            width: 100%;
            text-align: center;
            animation: modalIn 0.3s ease;
            box-shadow: var(--shadow);
        }

        .login-box .lock-icon {
            font-size: 44px;
            display: block;
            margin-bottom: 8px;
        }

        .login-box h2 {
            color: var(--text);
            font-size: 20px;
            margin-bottom: 4px;
        }

        .login-box p {
            color: var(--text-muted);
            font-size: 12px;
            margin-bottom: 16px;
        }

        .login-box .form-group {
            margin-bottom: 14px;
            text-align: left;
        }

        .login-box .form-group label {
            display: block;
            font-size: 10px;
            font-weight: 600;
            color: var(--text-muted);
            margin-bottom: 3px;
            letter-spacing: 0.5px;
        }

        .login-box .form-group input {
            width: 100%;
            padding: 9px 12px;
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid var(--border);
            border-radius: 8px;
            color: var(--text);
            font-size: 13px;
            transition: var(--transition);
        }

        .login-box .form-group input:focus {
            border-color: var(--primary);
            outline: none;
            box-shadow: 0 0 0 3px rgba(139, 122, 90, 0.1);
        }

        .login-box .btn-login {
            width: 100%;
            padding: 10px;
            background: var(--primary);
            color: #0d0a08;
            border: none;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            transition: var(--transition);
        }

        .login-box .btn-login:hover {
            background: var(--primary-light);
            transform: translateY(-2px);
        }

        .login-box .error-msg {
            color: #cc4444;
            font-size: 11px;
            margin-top: 8px;
            display: none;
        }

        .login-box .error-msg.show {
            display: block;
        }

        .login-box .admin-hint {
            margin-top: 14px;
            padding-top: 14px;
            border-top: 1px solid var(--border);
            font-size: 10px;
            color: var(--text-muted);
        }

        .login-box .admin-hint span {
            color: var(--primary-light);
            font-weight: 600;
        }

        /* ============================================================
           MAIN
           ============================================================ */
        .main {
            max-width: 1200px;
            margin: 0 auto;
            padding: 16px 16px 30px;
            flex: 1;
        }

        #page-accueil { display: block; }
        #page-admin { display: none; }
        #page-logos { display: none; }
        #page-texts { display: none; }
        #page-force { display: none; }
        #page-insigne { display: none; }
        #page-categorie { display: none; }
        #page-contact { display: none; }
        #page-documentation { display: none; }
        #page-change-password { display: none; }

        /* ============================================================
           BREADCRUMB
           ============================================================ */
        .breadcrumb {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 11px;
            color: var(--text-muted);
            margin-bottom: 16px;
            padding: 6px 12px;
            background: var(--bg-card);
            border-radius: var(--radius);
            border: 1px solid var(--border);
            flex-wrap: wrap;
        }

        .breadcrumb a {
            color: var(--primary-light);
            text-decoration: none;
            cursor: pointer;
            transition: var(--transition);
        }

        .breadcrumb a:hover {
            color: var(--text);
        }

        .breadcrumb .sep {
            color: var(--text-muted);
        }

        .breadcrumb .current {
            color: var(--text);
            font-weight: 500;
        }

        /* ============================================================
           SECTIONS
           ============================================================ */
        .section {
            margin: 30px 0;
        }

        .section-header {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 16px;
            padding-bottom: 8px;
            border-bottom: 1px solid var(--border);
        }

        .section-header h2 {
            font-size: 18px;
            font-weight: 600;
            color: var(--text);
            letter-spacing: 0.5px;
        }

        .section-header .badge {
            background: rgba(139, 122, 90, 0.1);
            color: var(--primary-light);
            padding: 2px 10px;
            border-radius: 16px;
            font-size: 9px;
            font-weight: 500;
            letter-spacing: 0.3px;
        }

        .section-header .back-btn {
            margin-left: auto;
            background: transparent;
            border: 1px solid var(--border);
            color: var(--text-muted);
            padding: 3px 12px;
            border-radius: 6px;
            font-size: 10px;
            cursor: pointer;
            transition: var(--transition);
        }

        .section-header .back-btn:hover {
            border-color: var(--primary);
            color: var(--text);
            background: rgba(139, 122, 90, 0.05);
        }

        /* ============================================================
           CARTES
           ============================================================ */
        .cards-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
            gap: 16px;
        }

        .card {
            background: var(--bg-card);
            border-radius: var(--radius);
            overflow: hidden;
            border: 1px solid var(--border);
            transition: var(--transition);
            cursor: pointer;
        }

        .card:hover {
            transform: translateY(-4px);
            border-color: rgba(139, 122, 90, 0.3);
            box-shadow: var(--shadow);
            background: var(--bg-card-hover);
        }

        .card-img {
            height: 150px;
            background-size: cover;
            background-position: center;
            position: relative;
        }

        .card-img .tag {
            position: absolute;
            top: 8px;
            right: 8px;
            background: rgba(139, 122, 90, 0.9);
            color: #0d0a08;
            padding: 2px 8px;
            border-radius: 10px;
            font-size: 8px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .card-img .period-tag {
            position: absolute;
            bottom: 8px;
            left: 8px;
            background: rgba(0, 0, 0, 0.65);
            color: var(--text-muted);
            padding: 2px 8px;
            border-radius: 10px;
            font-size: 8px;
            backdrop-filter: blur(5px);
        }

        .card-body {
            padding: 14px;
        }

        .card-body h4 {
            font-size: 14px;
            font-weight: 600;
            color: var(--text);
            margin-bottom: 2px;
        }

        .card-body .location {
            font-size: 10px;
            color: var(--primary);
            margin-bottom: 4px;
        }

        .card-body .desc {
            font-size: 11px;
            color: var(--text-muted);
            line-height: 1.5;
            margin-bottom: 5px;
        }

        .card-body .tags {
            display: flex;
            flex-wrap: wrap;
            gap: 3px;
            margin-bottom: 5px;
        }

        .card-body .tags span {
            background: rgba(139, 122, 90, 0.06);
            color: var(--text-muted);
            padding: 1px 6px;
            border-radius: 8px;
            font-size: 8px;
        }

        .card-body .date {
            font-size: 9px;
            color: #5a4a3a;
        }

        .card-body .btn-detail {
            display: inline-block;
            margin-top: 6px;
            background: transparent;
            color: var(--primary-light);
            padding: 3px 0;
            border: none;
            border-bottom: 1px solid var(--primary);
            font-size: 10px;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
        }

        .card-body .btn-detail:hover {
            color: var(--text);
            border-bottom-color: var(--text);
        }

        /* ============================================================
           FORCES - GRILLE DE NAVIGATION
           ============================================================ */
        .forces-nav-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
            gap: 12px;
            margin: 16px 0;
        }

        .force-nav-item {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 16px 10px;
            text-align: center;
            transition: var(--transition);
            cursor: pointer;
        }

        .force-nav-item:hover {
            border-color: rgba(139, 122, 90, 0.3);
            transform: translateY(-3px);
            box-shadow: var(--shadow);
            background: var(--bg-card-hover);
        }

        .force-nav-item .icon {
            font-size: 28px;
            display: block;
            margin-bottom: 4px;
        }

        .force-nav-item .icon img {
            width: 28px;
            height: 28px;
            object-fit: contain;
            border-radius: 4px;
        }

        .force-nav-item .name {
            font-size: 11px;
            font-weight: 500;
            color: var(--text);
            display: block;
        }

        .force-nav-item .count {
            font-size: 8px;
            color: var(--text-muted);
            display: block;
            margin-top: 2px;
        }

        .force-nav-item .sub {
            font-size: 7px;
            color: var(--text-muted);
            display: block;
            margin-top: 2px;
            opacity: 0.6;
        }

        .force-nav-item .category-badge {
            display: inline-block;
            margin-top: 4px;
            background: rgba(139, 122, 90, 0.15);
            color: var(--primary-light);
            padding: 1px 8px;
            border-radius: 10px;
            font-size: 7px;
        }

        /* ============================================================
           INSIGNES - GRILLE DE NAVIGATION
           ============================================================ */
        .insignes-nav-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
            gap: 14px;
            margin: 16px 0;
        }

        .insigne-nav-item {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 16px 12px;
            text-align: center;
            transition: var(--transition);
            cursor: pointer;
        }

        .insigne-nav-item:hover {
            border-color: rgba(139, 122, 90, 0.3);
            transform: translateY(-3px);
            box-shadow: var(--shadow);
            background: var(--bg-card-hover);
        }

        .insigne-nav-item .icon {
            font-size: 32px;
            display: block;
            margin-bottom: 4px;
        }

        .insigne-nav-item .icon img {
            width: 32px;
            height: 32px;
            object-fit: contain;
            border-radius: 4px;
        }

        .insigne-nav-item .name {
            font-size: 11px;
            font-weight: 500;
            color: var(--text);
        }

        .insigne-nav-item .desc {
            font-size: 9px;
            color: var(--text-muted);
            margin-top: 2px;
        }

        .insigne-nav-item .meta {
            display: flex;
            justify-content: center;
            gap: 4px;
            margin-top: 4px;
            flex-wrap: wrap;
        }

        .insigne-nav-item .meta span {
            background: rgba(139, 122, 90, 0.06);
            color: var(--text-muted);
            padding: 1px 6px;
            border-radius: 8px;
            font-size: 7px;
        }

        /* ============================================================
           PAGE FORCE
           ============================================================ */
        .force-entries {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
            gap: 16px;
            margin-top: 12px;
        }

        .force-entry-card {
            background: var(--bg-card);
            border-radius: var(--radius);
            overflow: hidden;
